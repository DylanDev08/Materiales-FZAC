NODE_ENV=development
PORT=4000
CLIENT_URL=http://localhost:5173
API_URL=http://localhost:4000

# Supabase Postgres en producción.
# Para desarrollo local podés usar Docker/Postgres local con estos valores.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/materiales_fzac?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/materiales_fzac?schema=public"

JWT_ACCESS_SECRET="fzac_access_secret_local_2026"
JWT_REFRESH_SECRET="fzac_refresh_secret_local_2026"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Si STRIPE_SECRET_KEY queda vacío en development, checkout usa modo simulado funcional.
# En production es obligatorio configurar Stripe real.
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_CURRENCY=ars

# Cloudinary solo es necesario si cargás imágenes desde admin.
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Materiales FZAC <ventas@materialesfzac.com>"

# Mercado Pago / billeteras
MERCADOPAGO_ACCESS_TOKEN=""
MERCADOPAGO_PUBLIC_KEY=""
MERCADOPAGO_WEBHOOK_SECRET=""

# Supabase Auth (Google OAuth)
SUPABASE_URL=""
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# FZAC IA Assistant (OpenAI Responses API)
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
ASSISTANT_ENABLED=true
