NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRODUCT_IMAGES_BUCKET=product-images
SUPABASE_URL=
SUPABASE_ANON_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# MERCADOPAGO_ACCESS_TOKEN va solo en servidor.
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY puede estar en frontend.
# No subir .env.local a GitHub.
PAYMENTS_ENABLED=true
PAYMENT_ENABLED=true
PAYMENTS_ENV=test
PAYMENTS_PROVIDER=mercadopago
# Produccion exige confirmacion explicita y credenciales separadas.
# No cambies PAYMENTS_ENV hasta completar el checklist del panel Sistema.
PAYMENTS_PRODUCTION_CONFIRMED=false
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_PUBLIC_KEY=
# Opcional: separar credenciales por flujo para evitar mezclar sandbox/test.
# Checkout Pro/link/redireccion puede usar credenciales del vendedor test.
MERCADOPAGO_CHECKOUT_PRO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_CHECKOUT_PRO_PUBLIC_KEY=
# Nunca reutilizar las credenciales anteriores al pasar a cobros reales.
MERCADOPAGO_PRODUCTION_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PRODUCTION_PUBLIC_KEY=
# Card Brick/tarjeta debe usar credenciales de prueba del vendedor real.
# Habilitar solo despues de validar ambas claves con una tarjeta sandbox rechazada.
MERCADOPAGO_CARD_ENABLED=false
MERCADOPAGO_CARD_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_CARD_PUBLIC_KEY=
MERCADOPAGO_PRODUCTION_CARD_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PRODUCTION_CARD_PUBLIC_KEY=
PURCHASE_AUTO_APPROVAL_LIMIT=250000

ADMIN_EMAIL=
ADMIN_EMAILS=
ADMIN_CONSOLE_PATH=/fzac-admin-crs-2026

# Resend se usa solo en servidor para emails transaccionales de Auth.
# RESEND_FROM_EMAIL debe pertenecer a un dominio verificado en Resend.
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_FROM_NAME=Materiales FZAC

# El comprobante FZAC no es una factura fiscal. Habilitar solo al integrar
# un proveedor fiscal/ARCA con certificado y punto de venta validados.
FISCAL_INVOICING_ENABLED=false
FISCAL_INVOICING_PROVIDER=

NEXT_PUBLIC_FZAC_WHATSAPP=
FZAC_WHATSAPP=
WHATSAPP_NUMBER=
NEXT_PUBLIC_FZAC_EMAIL=
FZAC_EMAIL=
FZAC_INSTAGRAM=

# Desactiva escrituras del asistente solamente para pruebas locales de carga.
ASSISTANT_PERSISTENCE_ENABLED=true

NARANJAX_API_BASE_URL=
NARANJAX_CLIENT_ID=
NARANJAX_CLIENT_SECRET=
NARANJAX_ENABLED=false
