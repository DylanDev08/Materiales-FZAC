NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_PRODUCT_IMAGES_BUCKET=product-images
SUPABASE_URL=
SUPABASE_ANON_KEY=

NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# MERCADOPAGO_ACCESS_TOKEN va solo en servidor.
# NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY puede estar en frontend.
# No subir .env.local a GitHub.
PAYMENTS_ENABLED=true
PAYMENT_ENABLED=true
PAYMENTS_ENV=test
PAYMENTS_PROVIDER=mercadopago
MERCADOPAGO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_PUBLIC_KEY=
MERCADOPAGO_WEBHOOK_SECRET=
MERCADOPAGO_PUBLIC_KEY=
# Opcional: separar credenciales por flujo para evitar mezclar sandbox/test.
# Checkout Pro/link/redireccion puede usar credenciales del vendedor test.
MERCADOPAGO_CHECKOUT_PRO_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_CHECKOUT_PRO_PUBLIC_KEY=
# Card Brick/tarjeta debe usar credenciales de prueba del vendedor real.
MERCADOPAGO_CARD_ACCESS_TOKEN=
NEXT_PUBLIC_MERCADOPAGO_CARD_PUBLIC_KEY=
PURCHASE_AUTO_APPROVAL_LIMIT=250000

ADMIN_EMAIL=
ADMIN_EMAILS=
ADMIN_CONSOLE_PATH=/fzac-admin-crs-2026

# Sender se usa solo en servidor para emails transaccionales de Auth.
# SENDER_FROM_EMAIL debe pertenecer a un dominio verificado en Sender.
SENDER_API_KEY=
SENDER_FROM_EMAIL=
SENDER_FROM_NAME=Materiales FZAC

NEXT_PUBLIC_FZAC_WHATSAPP=
FZAC_WHATSAPP=
WHATSAPP_NUMBER=
NEXT_PUBLIC_FZAC_EMAIL=
FZAC_EMAIL=
FZAC_INSTAGRAM=

# Desactiva escrituras del asistente solamente para pruebas locales de carga.
ASSISTANT_PERSISTENCE_ENABLED=true

NARANJAX_API_BASE_URL=
NARANJAX_CLIENT_ID=
NARANJAX_CLIENT_SECRET=
NARANJAX_ENABLED=false
